```mermaid
graph TD
    subgraph "用户界面 (UI)"
        A["Activity/Fragment"] --> B("ViewModel");
        C("RecyclerView.Adapter") -- "数据" --> A;
        D("XML Layouts") -- "视图" --> A;
    end

    subgraph "业务逻辑 (ViewModel)"
        B -- "调用" --> E{"UseCase"};
    end

    subgraph "领域层 (Domain)"
        E -- "协调" --> F["Repository"];
    end

    subgraph "数据层 (Data)"
        F -- "委托" --> G("RemoteDataSource");
        F -- "委托" --> H("LocalDataSource");
        G -- "请求" --> I["Retrofit Service"];
        H -- "读写" --> J["Room Database"];
    end

    subgraph "核心层 (Core)"
        I -- "依赖" --> K("OkHttpClient");
        K -- "拦截" --> L["HeaderInterceptor"];
        M("AppPreferences") -- "提供数据" --> L;
        N("LocationProvider") -- "提供数据" --> L;
        O("ServiceLocator") -.-> B & F & L;
    end
```